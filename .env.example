# Upstash Redis (Vercel KV / Redis integration)
# Vercel injects KV_REST_* ; Upstash CLI uses UPSTASH_REDIS_*
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Admin authentication
ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-long-random-string

# Public site URL (metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://syedabbas.com
